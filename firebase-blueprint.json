{
  "entities": {
    "CacheEntry": {
      "title": "AI Cache Entry",
      "description": "Stored AI responses to avoid redundant generation",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "description": "The type of content (lesson, quiz, etc.)"
        },
        "params": {
          "type": "object",
          "description": "The parameters used for generation"
        },
        "response": {
          "type": "object",
          "description": "The cached AI response"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the entry was created"
        }
      },
      "required": ["type", "params", "response", "timestamp"]
    },
    "Generation": {
      "title": "Generation Metadata",
      "description": "Metadata about an AI generation event",
      "type": "object",
      "properties": {
        "contentType": { "type": "string" },
        "topic": { "type": "string" },
        "grade": { "type": "string" },
        "tokens": { "type": "number" },
        "model": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["contentType", "topic", "grade", "timestamp"]
    },
    "Quota": {
      "title": "Daily Quota",
      "description": "Daily usage tracking for AI generation",
      "type": "object",
      "properties": {
        "count": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["count", "lastUpdated"]
    },
    "LibraryItem": {
      "title": "Library Item",
      "description": "A saved piece of content in the teacher's library",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string" },
        "grade": { "type": "string" },
        "userId": { "type": "string" },
        "isGlobal": { "type": "boolean", "description": "Whether this item is available to all users" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "type", "grade", "userId", "createdAt"]
    }
  },
  "firestore": {
    "ai_cache/{cacheId}": {
      "schema": "CacheEntry",
      "description": "Collection for caching AI responses"
    },
    "generations/{genId}": {
      "schema": "Generation",
      "description": "Collection for tracking AI generations"
    },
    "quotas/{date}": {
      "schema": "Quota",
      "description": "Collection for tracking daily AI usage quotas"
    },
    "library/{itemId}": {
      "schema": "LibraryItem",
      "description": "Collection for teacher's saved library items"
    }
  }
}
